20 ps MM MD (quick) heating of system
&cntrl
 imin=0, ! Not minimization
 irest=0, ! Do not restart with velocities
 ntx=1, ! Read restart coordinates but not velocities
 ig=-1, ! Random seed
 nstlim=10000, ! Number of steps
 dt=0.002, ! Timestep
 ntpr=1000, ! Energy output every ntpr steps
 ntwx=1000, ! Write coordinates every ntwx steps to mdcrd file
 ioutfm=1,
 ntb=2, ! Periodic box used
 cut=8.0, ! Non-bonded cutoff
 ntc=2, ! SHAKE for bonds with H
 ntf=2, ! Omit bonds with H atoms
 ntp=1, ! Constant pressure dynamics with isotropic scaling
 ntt=3, ! Langevin dynamics
 gamma_ln=0.2, ! Collision frequency for Langevin
 tempi=50.0, ! Initial temperature
 temp0=300.0, ! End temperature
 ifqnt=0, ! No QM/MM
 nmropt=1,
&end
 &wt TYPE='DUMPFREQ', istep1=500 /
 &wt TYPE='END' /
 DISANG=../md_restrains.rst
 DUMPAVE=heat.tra
/
